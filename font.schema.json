{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "font.schema.json",
  "title": "Font Metadata",
  "type": "object",
  "required": ["id", "name", "version", "license", "source", "files"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "description": "URL-safe identifier (kebab-case)"
    },
    "name": {
      "type": "string",
      "description": "Display name (English)"
    },
    "nameLocal": {
      "type": "string",
      "description": "Native language name"
    },
    "description": {
      "type": "string",
      "maxLength": 200,
      "description": "Brief description"
    },
    "category": {
      "type": "string",
      "enum": ["serif", "sans-serif", "monospace", "display", "handwriting", "cjk"],
      "description": "Font category"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?(-[a-z0-9]+)?$",
      "description": "Upstream font version (semver compatible)"
    },
    "license": {
      "type": "object",
      "required": ["spdx", "url"],
      "properties": {
        "spdx": {
          "type": "string",
          "description": "SPDX license identifier"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Link to license text"
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Upstream repository or download URL"
        },
        "type": {
          "type": "string",
          "enum": ["github", "google-fonts", "other"],
          "description": "Source type for automation hints"
        }
      }
    },
    "fetch": {
      "type": "object",
      "description": "Fetch script configuration for downloading from upstream",
      "properties": {
        "script": {
          "type": "string",
          "description": "Fetch script filename (relative to font directory)"
        },
        "upstreamRepo": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$",
          "description": "Upstream GitHub repo (owner/name)"
        },
        "assetPattern": {
          "type": "string",
          "description": "Asset filename pattern, {version} will be replaced"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes for fetching"
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["filename", "weight", "style"],
        "properties": {
          "filename": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+\\.woff2$",
            "description": "Font filename"
          },
          "weight": {
            "type": "integer",
            "minimum": 100,
            "maximum": 900,
            "multipleOf": 100,
            "description": "CSS font-weight value"
          },
          "style": {
            "type": "string",
            "enum": ["normal", "italic", "oblique"],
            "description": "CSS font-style value"
          },
          "displayName": {
            "type": "string",
            "description": "Human-readable weight name"
          }
        }
      }
    },
    "subsets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Character subsets"
    },
    "deprecated": {
      "type": "boolean",
      "default": false,
      "description": "Mark font as deprecated"
    },
    "deprecatedReason": {
      "type": "string",
      "description": "Reason for deprecation"
    },
    "deprecatedDate": {
      "type": "string",
      "format": "date",
      "description": "Date when deprecated"
    },
    "replacement": {
      "type": "string",
      "description": "Suggested replacement font ID"
    },
    "added": {
      "type": "string",
      "format": "date",
      "description": "Date when added to CDN"
    },
    "maintainer": {
      "type": "string",
      "description": "GitHub username of font maintainer"
    }
  }
}
